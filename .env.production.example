# Production / cloud — copy to .env before docker compose or platform deploy.
# NEXT_PUBLIC_* vars are baked into the web Docker image at BUILD time.

# Public URLs (browser-reachable; no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Database & queue (managed Postgres/Redis on Render, Railway, etc.)
DATABASE_URL=postgresql://user:pass@host:5432/solutiva_court?schema=public
REDIS_URL=redis://default:pass@host:6379

# API
API_PORT=4000
CHAIN_ENABLED=false
OPENAI_API_KEY=

# Web build args (must match NEXT_PUBLIC_* above when using docker-compose.prod.yml)
NEXT_PUBLIC_CHAIN_ENABLED=false

# Optional: hybrid on-chain (see .env.example)
# CHAIN_ID=11155111
# AVF_TOKEN_ADDRESS=0x45D39B5C90685AF368EecbacB6EB7bbA6f9B1936
