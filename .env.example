# Database
DATABASE_URL="postgresql://solutiva:solutiva_dev@localhost:5437/solutiva_court?schema=public"

# Redis
REDIS_URL="redis://localhost:6382"

# API
API_PORT=4000
API_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Next.js
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# AI (OpenAI-compatible)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Google Indexing API
GOOGLE_INDEXING_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
GOOGLE_INDEXING_SITE_URL="https://solutivacourt.com"

# Hybrid on-chain layer (default: Ethereum Sepolia + AVF testnet token)
# Verified AVF_Token (ERC-223) from EthereumCommonwealth:
# https://github.com/EthereumCommonwealth/AVF_Token
# Sepolia: https://sepolia.etherscan.io/address/0x45D39B5C90685AF368EecbacB6EB7bbA6f9B1936#code
# Off-chain: disputes, jury votes, AI, activity feed, SEO
CHAIN_ENABLED=false
CHAIN_ID=11155111
CHAIN_RPC_URL="https://rpc.sepolia.org"
BASE_RPC_URL="https://rpc.sepolia.org"
RELAYER_PRIVATE_KEY=""
AVF_TOKEN_ADDRESS="0x45D39B5C90685AF368EecbacB6EB7bbA6f9B1936"
DISPUTE_ESCROW_ADDRESS=""
OUTCOME_REGISTRY_ADDRESS=""
# Set true only if RELAYER_PRIVATE_KEY is the AVF_Token owner (mint is owner-only on Sepolia)
AVF_REWARDS_ON_CHAIN=false

# Web (mirror API contract addresses)
NEXT_PUBLIC_CHAIN_ENABLED=false
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_CHAIN_RPC_URL="https://rpc.sepolia.org"
NEXT_PUBLIC_BASE_RPC_URL="https://rpc.sepolia.org"
NEXT_PUBLIC_AVF_TOKEN_ADDRESS="0x45D39B5C90685AF368EecbacB6EB7bbA6f9B1936"
NEXT_PUBLIC_DISPUTE_ESCROW_ADDRESS=""
NEXT_PUBLIC_OUTCOME_REGISTRY_ADDRESS=""
