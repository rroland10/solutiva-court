generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DisputeStatus {
  PENDING
  ACTIVE
  RESOLVED
  CANCELLED
}

enum DisputeCategory {
  CONTRACT
  PAYMENT
  SERVICE
  INTELLECTUAL
  EMPLOYMENT
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  name          String?
  email         String?  @unique
  trustScore    Float    @default(50)
  avfBalance    Float    @default(0)
  isJuryMember  Boolean  @default(false)
  chainId       Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  disputesCreated Dispute[] @relation("PlaintiffDisputes")
  votes           Vote[]
  activities      Activity[]
}

model Dispute {
  id          String          @id @default(cuid())
  caseNumber  Int             @unique @default(autoincrement())
  title       String
  description String
  category    DisputeCategory
  status      DisputeStatus   @default(PENDING)
  collateral  Float
  jurySize    Int             @default(6)
  deadline    DateTime?
  aiSummary   String?
  resolutionOutcome String?
  disputeKey        String?         @unique
  escrowTxHash      String?
  outcomeHash       String?
  outcomeTxHash     String?
  chainId           Int?
  plaintiffId String
  defendantAddress String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  plaintiff User   @relation("PlaintiffDisputes", fields: [plaintiffId], references: [id])
  votes     Vote[]
}

model Vote {
  id        String   @id @default(cuid())
  disputeId String
  userId    String
  choice    String
  createdAt DateTime @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([disputeId, userId])
}

model Activity {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  title     String
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model PlatformStats {
  id              String   @id @default("default")
  activeDisputes  Int      @default(0)
  juryMembers     Int      @default(0)
  resolutionRate  Float    @default(0)
  totalStaked     Float    @default(0)
  updatedAt       DateTime @updatedAt
}

model SeoIndexLog {
  id        String   @id @default(cuid())
  url       String
  status    String
  response  Json?
  createdAt DateTime @default(now())
}
